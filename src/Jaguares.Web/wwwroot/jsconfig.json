{
    // Define el "proyecto" JavaScript del frontend para VS Code.
    // checkJs: true -> el editor valida tipos y nulos en los .js y en los <script> de los .html.
    // Con globals.d.ts incluido, reconoce apiFetch/Swal/confetti/etc.
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ]
    },
    "include": [
        "**/*.js",
        "globals.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
