{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "__SET_IN_appsettings.{Environment}.json_OR_ENV__",
    "Remote": "__SET_IN_appsettings.{Environment}.json_OR_ENV__"
  },
  "Jwt": {
    "Key": "__SET_IN_appsettings.{Environment}.json_OR_ENV__",
    "Issuer": "JaguaresSwimApi",
    "Audience": "JaguaresSwimWeb",
    "ExpireHours": "8"
  },
  "Admin": {
    "Password": "__SET_IN_appsettings.{Environment}.json_OR_ENV__"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5000",
      "https://localhost:5001",
      "https://cristests.runasp.net"
    ]
  }
}
